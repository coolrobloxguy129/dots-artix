general {
    colors = true
    interval = 5
    color_good = "#ffffff"
    color_degraded = "#ffcc00"
    color_bad = "#ff3b30"
}

order += "wireless _first_"
order += "battery all"
order += "tztime local"

wireless _first_ {
    format_up = "    "
    format_down = "    "
}

battery all {
    format = " %percentage "
    status_chr = "  "
    status_bat = ""
    status_full = ""
}

tztime local {
    format = " %a %b %d  %H:%M "
}
